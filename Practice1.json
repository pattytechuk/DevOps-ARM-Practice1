    "contentVersion": "1.0.0.0",
    "parameters": {
        "storageAccountName": {
        "type": "string",
        "metadata": {
        "description": "The name of the storage account to create."
      }
    }, 
    "functions": [],
    "variables": {}, 
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-01-01",
